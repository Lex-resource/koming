# ============ LLM 多厂商多模型配置 ============
# 通用密钥（向后兼容，仅应用到未单独配置的模型）
LLM_API_KEY=your_glm_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_DEFAULT_MODEL=glm-4.5-flash

# 按模型名独立配置（前缀 MODEL_<NAME>_，模型名大写，. 和 - 替换为 _）
# 示例：MODEL_GLM_4_5 表示模型名 glm-4.5
MODEL_GLM_4_5_API_KEY=
MODEL_GLM_4_5_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
MODEL_GLM_4_5_PROVIDER=openai_compatible
MODEL_GLM_4_5_MODEL=glm-4.5
MODEL_GLM_4_5_TEMPERATURE=0.3

MODEL_GLM_4_5_FLASH_API_KEY=
MODEL_GLM_4_5_FLASH_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
MODEL_GLM_4_5_FLASH_PROVIDER=openai_compatible
MODEL_GLM_4_5_FLASH_MODEL=glm-4.5-flash
MODEL_GLM_4_5_FLASH_TEMPERATURE=0.2

# 其他厂商示例（取消注释并填入密钥即可启用）
# MODEL_QWEN_MAX_API_KEY=
# MODEL_QWEN_MAX_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MODEL_QWEN_MAX_PROVIDER=openai_compatible
# MODEL_QWEN_MAX_MODEL=qwen-max

# MODEL_DEEPSEEK_CHAT_API_KEY=
# MODEL_DEEPSEEK_CHAT_BASE_URL=https://api.deepseek.com/v1
# MODEL_DEEPSEEK_CHAT_PROVIDER=openai_compatible
# MODEL_DEEPSEEK_CHAT_MODEL=deepseek-chat

# ============ Embedding 配置 ============
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
EMBEDDING_MODEL=embedding-3

# ============ 各智能体模型选择 ============
ORCHESTRATOR_MODEL=glm-4.5
WORKER_MODEL=glm-4.5-flash
REVIEWER_MODEL=glm-4.5
ORCHESTRATOR_MAX_ROUNDS=10
WORKER_TIMEOUT=120

# ============ 记忆配置 ============
MEMORY_PROVIDER=chromadb
MEMORY_PERSIST_PATH=./data/vector_store

# ============ 缓存配置 ============
CACHE_PROVIDER=memory
# CACHE_PROVIDER=redis
REDIS_HOST=localhost
REDIS_PORT=6379

# ============ 数据库配置 ============
DATABASE_PROVIDER=sqlite
DATABASE_URL=sqlite:///./data/jarvis.db

# ============ 设备控制配置 ============
DEVICE_PROVIDER=mock
# DEVICE_PROVIDER=mcp
# MCP_SERVER_URL=

# ============ 存储配置 ============
SESSION_DIR=./sessions

# ============ 全局配置 ============
JARVIS_CONFIG_FILE=
